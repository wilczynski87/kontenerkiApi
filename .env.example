API_ENV=DEV
INTERNAL_API_KEY=secret123

JWT_SECRET=secret
JWT_AUDIENCE=jwt-audience
JWT_REALM=ktor sample app
VALIDITY_MS=60000
APP_LOGIN=ppp
APP_SECRET=ppp

