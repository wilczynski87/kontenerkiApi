# Copy this file to .env and fill in your values:
#   cp .env.example .env

# === PostgreSQL ===
POSTGRES_USER=admin_user
POSTGRES_PASSWORD=postgres
POSTGRES_DB=db1

# === Database connection ===
# For docker compose: DB_HOST=db, DB_PORT=5432
# For local ./gradlew run: DB_HOST=localhost, DB_PORT=5431
DB_HOST=db
DB_PORT=5432
DB_NAME=db1
DB_USER=admin_user
DB_PASSWORD=postgres

# === API ===
API_PORT=8100
API_ENV=DEV
ENV=DEV

# === JWT (required - app won't start without it) ===
JWT_SECRET=change-me-in-production
JWT_ISSUER=ktor sample app
JWT_AUDIENCE=jwt-audience
JWT_REALM=ktor sample app
VALIDITY_MS=3600000

# === Auth ===
APP_LOGIN=
APP_SECRET=

# === Email ===
EMAIL_HOST=email
EMAIL_PORT=8200

# === Google OAuth ===
GOOGLE_CLIENT_ID=
