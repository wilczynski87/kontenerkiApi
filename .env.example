# cp .env.example .env — then paste real GOOGLE_* secrets and KSEF_TOKEN into .env only

# === PostgreSQL (docker compose) ===
POSTGRES_USER=admin_user
POSTGRES_PASSWORD=postgres
POSTGRES_DB=db1

# === DB ===
DB_HOST=localhost
DB_NAME=db1
DB_USER=admin_user
DB_PASSWORD=postgres
DB_PORT=5432
# Po imporcie zrzutu SQL: ustaw false, jeśli migracja Exposed przy starcie się wywala
# DB_AUTO_MIGRATE=false

# === API ===
API_PORT=8100
API_ENV=DEV
INTERNAL_API_KEY=secret123

JWT_SECRET=secret
JWT_AUDIENCE=jwt-audience
JWT_REALM="ktor sample app"
VALIDITY_MS=60000
APP_LOGIN=ppp
APP_SECRET=ppp

# === GOOGLE ===
GOOGLE_CLIENT_ID=695782084929-utc9fibe15r1hirugo5g2trfnc80souv.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# === KSEF (DEV → sandbox TEST; token tylko w .env, nie commituj) ===
# Środowisko: TEST (sandbox), DEMO lub PRODUCTION — przy API_ENV=DEV domyślnie TEST
KSEF_ENV=TEST
KSEF_BASE_URL=https://api-test.ksef.mf.gov.pl
KSEF_API_SUFFIX=v2
# NIP podmiotu, dla którego wygenerowano token w portalu KSeF TEST (musi się zgadzać!)
KSEF_NIP=8943278612
# Token systemowy z portalu KSeF TEST (MCU) — NIP w tokenie musi = KSEF_NIP.
# Ze znakiem | użyj cudzysłowów LUB pliku (zalecane):
# KSEF_TOKEN="twoj-token|nip-8943278612|sekret"
KSEF_TOKEN=
# Zalecane: jedna linia tokenu w pliku (bez cudzysłowów w shellu)
# KSEF_TOKEN_FILE=./secrets/ksef-token.txt

# === EMAIL ===
ENV=DEV
API_NAME=localhost
EMAIL_HOST=localhost
EMAIL_USER=parkingostrowskiego@gmail.com
EMAIL_PORT=8200
PRINT_RECIPIENT=wilczynski87@gmail.com
