# Copy to .env: cp .env.example .env
# Fill OAuth / KSeF tokens in .env only — do not commit real secrets to git.

# === PostgreSQL (docker compose db service) ===
POSTGRES_USER=admin_user
POSTGRES_PASSWORD=postgres
POSTGRES_DB=db1

# === DB ===
DB_HOST=localhost
DB_NAME=db1
DB_USER=admin_user
DB_PASSWORD=postgres
DB_PORT=5432

# === API ===
