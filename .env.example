# Copy to .env and adjust values: cp .env.example .env
#
# DB_PORT is the host port for PostgreSQL (e.g. 5431 to avoid clashing with a local install).
# docker-compose maps DB_PORT -> 5432 inside the db container; the api service always uses 5432 on the internal network.

POSTGRES_USER=admin_user
POSTGRES_PASSWORD=postgres
POSTGRES_DB=db1

DB_HOST=localhost
DB_PORT=5431
DB_NAME=db1
DB_USER=admin_user
DB_PASSWORD=postgres

API_PORT=8100
API_ENV=DEV

JWT_SECRET=change-me-in-production

# Required by the email service (use real Google OAuth values in production)
GOOGLE_CLIENT_ID=dev-google-client-id
GOOGLE_CLIENT_SECRET=dev-google-client-secret
GOOGLE_REFRESH_TOKEN=dev-google-refresh-token
INTERNAL_API_KEY=dev-internal-api-key

EMAIL_PORT=8200
EMAIL_USER=dev@example.com

# Optional: KSeF integration
# KSEF_BASE_URL=https://api-test.ksef.mf.gov.pl
# KSEF_API_SUFFIX=v2
# KSEF_TOKEN=
# KSEF_NIP=
